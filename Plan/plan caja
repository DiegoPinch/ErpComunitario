CREATE TABLE expense_categories (
    category_id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL, -- Ejemplo: 'Sueldo Aguatero', 'Electricidad', 'Mantenimiento'
    description TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_VALUE
);

CREATE TABLE expenses (
    expense_id INT AUTO_INCREMENT PRIMARY KEY,
    category_id INT,             -- Relación con la categoría
    amount DECIMAL(10,2) NOT NULL, -- Cuánto dinero salió
    expense_date DATE NOT NULL,    -- Cuándo ocurrió (importante para reportes)
    description TEXT,              -- Notas adicionales (ej: "Compra de tubos para sector A")
    payment_method VARCHAR(50) DEFAULT 'cash', -- 'Efectivo', 'Transferencia', etc.
    reference_number VARCHAR(100), -- Número de factura o comprobante del gasto
    created_at TIMESTAMP DEFAULT CURRENT_VALUE,
    FOREIGN KEY (category_id) REFERENCES expense_categories(category_id)
);


